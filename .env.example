# ─── Database ─────────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:password@localhost:5432/apollo
# AWS RDS: postgresql://user:password@<rds-endpoint>:5432/apollo
DATABASE_URL="postgresql://user:password@localhost:5432/apollo"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: https://<your-ec2-domain-or-ip>
NEXTAUTH_URL="http://localhost:3000"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-secret-here"

# ─── AWS Credentials ──────────────────────────────────────────────────────────
# Use IAM user with SNS + SES permissions.
# In production (EC2), use IAM Role instead of access keys (leave these empty).
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="ap-southeast-1"

# ─── AWS SES ──────────────────────────────────────────────────────────────────
# Must be a verified email/domain in AWS SES
SES_FROM_EMAIL="no-reply@yourdomain.com"
